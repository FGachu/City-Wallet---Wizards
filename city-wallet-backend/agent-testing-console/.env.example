#
# Copy this file to `.env.local` and set real values.
# Do not commit real API keys.
#

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# Context and location (hydrate `grounding` server-side or in ETL)
OPENWEATHERMAP_API_KEY=

# Local demand signals
EVENTBRITE_PRIVATE_TOKEN=

# POI / footfall proxies (Places, Routes, or OSM proxy)
GOOGLE_MAPS_API_KEY=

# Payone / PSP (merchant transaction windows — use server-side only)
PAYONE_MERCHANT_API_KEY=
PAYONE_PARTNER_ID=

# Optional: custom backend/base API URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

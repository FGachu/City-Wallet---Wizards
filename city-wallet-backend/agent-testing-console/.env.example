#
# Copy this file to `.env.local` and set real values.
# Do not commit real API keys.
#

# External backend API (your real backend)
# Example: http://127.0.0.1:8000
AGENT_API_BASE_URL=
AGENT_API_KEY=

# OpenAI (optional; used by your backend if needed)
OPENAI_API_KEY=

# Context and location (live weather)
OPENWEATHERMAP_API_KEY=

# Local demand signals (optional)
EVENTBRITE_PRIVATE_TOKEN=

# POI / footfall proxies (optional)
GOOGLE_MAPS_API_KEY=

# Payone / PSP (optional)
PAYONE_MERCHANT_API_KEY=

# Optional: custom backend/base API URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

